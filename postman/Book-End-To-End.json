{
  "info": {
    "_postman_id": "c3d4e5f6-a7b8-9012-cdef-123456789012",
    "name": "Book End-To-End",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "gatewayUrl",    "value": "http://localhost:8080", "type": "string" },
    { "key": "userToken",     "value": "", "type": "string" },
    { "key": "staffToken",    "value": "", "type": "string" },
    { "key": "testBookTitle", "value": "", "type": "string" },
    { "key": "testBookId",    "value": "", "type": "string" },
    { "key": "testCopyId",    "value": "", "type": "string" }
  ],
  "item": [

    {
      "name": "1 - Auth Setup",
      "item": [
        {
          "name": "Register USER account",
          "request": {
            "method": "POST",
            "url": { "raw": "{{gatewayUrl}}/api/auth/register", "host": ["{{gatewayUrl}}"], "path": ["api","auth","register"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"book-user@elibrary.ie\",\n  \"password\": \"Test@12345\",\n  \"role\": \"USER\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('USER account ready (201 or 409)', function () {",
            "    pm.expect(pm.response.code).to.be.oneOf([201, 409]);",
            "});"
          ]}}]
        },
        {
          "name": "Register STAFF account",
          "request": {
            "method": "POST",
            "url": { "raw": "{{gatewayUrl}}/api/auth/register", "host": ["{{gatewayUrl}}"], "path": ["api","auth","register"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"book-staff@elibrary.ie\",\n  \"password\": \"Test@12345\",\n  \"role\": \"STAFF\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('STAFF account ready (201 or 409)', function () {",
            "    pm.expect(pm.response.code).to.be.oneOf([201, 409]);",
            "});"
          ]}}]
        },
        {
          "name": "Login as USER",
          "request": {
            "method": "POST",
            "url": { "raw": "{{gatewayUrl}}/api/auth/login", "host": ["{{gatewayUrl}}"], "path": ["api","auth","login"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"book-user@elibrary.ie\",\n  \"password\": \"Test@12345\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('USER login returns 200', function () { pm.response.to.have.status(200); });",
            "const body = pm.response.json();",
            "pm.test('Access token present', function () { pm.expect(body).to.have.property('token'); });",
            "pm.collectionVariables.set('userToken', body.token);"
          ]}}]
        },
        {
          "name": "Login as STAFF",
          "request": {
            "method": "POST",
            "url": { "raw": "{{gatewayUrl}}/api/auth/login", "host": ["{{gatewayUrl}}"], "path": ["api","auth","login"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"book-staff@elibrary.ie\",\n  \"password\": \"Test@12345\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('STAFF login returns 200', function () { pm.response.to.have.status(200); });",
            "const body = pm.response.json();",
            "pm.test('Access token present', function () { pm.expect(body).to.have.property('token'); });",
            "pm.collectionVariables.set('staffToken', body.token);"
          ]}}]
        }
      ]
    },

    {
      "name": "2 - Access Control",
      "item": [
        {
          "name": "Add title without auth token (expect 401)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{gatewayUrl}}/api/books/addTitle", "host": ["{{gatewayUrl}}"], "path": ["api","books","addTitle"] },
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title",         "value": "Unauthorised Book", "type": "text" },
                { "key": "author",        "value": "Nobody",           "type": "text" },
                { "key": "description",   "value": "Should not be created.", "type": "text" },
                { "key": "yearPublished", "value": "2020",             "type": "text" },
                { "key": "genre",         "value": "NONFICTION",       "type": "text" },
                { "key": "language",      "value": "ENGLISH",          "type": "text" }
              ]
            }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('No token on addTitle returns 401', function () { pm.response.to.have.status(401); });"
          ]}}]
        },
        {
          "name": "Add copy without auth token (expect 401)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{gatewayUrl}}/api/books/addCopy?titleId=1",
              "host": ["{{gatewayUrl}}"], "path": ["api","books","addCopy"],
              "query": [{ "key": "titleId", "value": "1" }]
            },
            "header": []
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('No token on addCopy returns 401', function () { pm.response.to.have.status(401); });"
          ]}}]
        },
        {
          "name": "Change copy status without auth token (expect 401)",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{gatewayUrl}}/api/books/changeStatus?copyId=1&status=ON_LOAN",
              "host": ["{{gatewayUrl}}"], "path": ["api","books","changeStatus"],
              "query": [{ "key": "copyId", "value": "1" }, { "key": "status", "value": "ON_LOAN" }]
            },
            "header": []
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('No token on changeStatus returns 401', function () { pm.response.to.have.status(401); });"
          ]}}]
        },
        {
          "name": "USER role cannot add copy (expect 403)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{gatewayUrl}}/api/books/addCopy?titleId=1",
              "host": ["{{gatewayUrl}}"], "path": ["api","books","addCopy"],
              "query": [{ "key": "titleId", "value": "1" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('USER role on addCopy returns 403', function () { pm.response.to.have.status(403); });",
            "pm.test('403 response has error body', function () {",
            "    const body = pm.response.json();",
            "    pm.expect(body).to.have.property('status', 403);",
            "});"
          ]}}]
        },
        {
          "name": "USER role cannot add title (expect 403)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{gatewayUrl}}/api/books/addTitle", "host": ["{{gatewayUrl}}"], "path": ["api","books","addTitle"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title",         "value": "Blocked Book", "type": "text" },
                { "key": "author",        "value": "Nobody",       "type": "text" },
                { "key": "description",   "value": "Blocked.",     "type": "text" },
                { "key": "yearPublished", "value": "2020",         "type": "text" },
                { "key": "genre",         "value": "NONFICTION",   "type": "text" },
                { "key": "language",      "value": "ENGLISH",      "type": "text" }
              ]
            }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('USER role on addTitle returns 403', function () { pm.response.to.have.status(403); });"
          ]}}]
        },
        {
          "name": "USER role cannot change status (expect 403)",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{gatewayUrl}}/api/books/changeStatus?copyId=1&status=ON_LOAN",
              "host": ["{{gatewayUrl}}"], "path": ["api","books","changeStatus"],
              "query": [{ "key": "copyId", "value": "1" }, { "key": "status", "value": "ON_LOAN" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('USER role on changeStatus returns 403', function () { pm.response.to.have.status(403); });"
          ]}}]
        }
      ]
    },

    {
      "name": "3 - Add Title (STAFF)",
      "item": [
        {
          "name": "Add new book title",
          "event": [
            {
              "listen": "prerequest",
              "script": { "type": "text/javascript", "exec": [
                "pm.collectionVariables.set('testBookTitle', 'E2E-Book-Test-' + Date.now());"
              ]}
            },
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('Add title returns 201', function () { pm.response.to.have.status(201); });",
                "const body = pm.response.json();",
                "pm.test('Response has id', function () { pm.expect(body).to.have.property('id'); });",
                "pm.test('Response title matches request', function () {",
                "    pm.expect(body.title).to.equal(pm.collectionVariables.get('testBookTitle'));",
                "});",
                "pm.test('Response has author', function () { pm.expect(body.author).to.equal('E2E Test Author'); });",
                "pm.test('Response has description', function () { pm.expect(body).to.have.property('description'); });",
                "pm.test('Response yearPublished matches', function () { pm.expect(body.yearPublished).to.equal(2024); });",
                "pm.test('Response genre is NONFICTION', function () { pm.expect(body.genre).to.equal('NONFICTION'); });",
                "pm.test('Response language is ENGLISH', function () { pm.expect(body.language).to.equal('ENGLISH'); });",
                "pm.test('copiesAvailable is 1 on creation', function () { pm.expect(body.copiesAvailable).to.equal(1); });",
                "pm.collectionVariables.set('testBookId', String(body.id));",
                "console.log('Created test book, id:', body.id, 'title:', body.title);"
              ]}
            }
          ],
          "request": {
            "method": "POST",
            "url": { "raw": "{{gatewayUrl}}/api/books/addTitle", "host": ["{{gatewayUrl}}"], "path": ["api","books","addTitle"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{staffToken}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title",         "value": "{{testBookTitle}}",                              "type": "text" },
                { "key": "author",        "value": "E2E Test Author",                                "type": "text" },
                { "key": "description",   "value": "A test book for end-to-end automated testing.", "type": "text" },
                { "key": "yearPublished", "value": "2024",                                           "type": "text" },
                { "key": "genre",         "value": "NONFICTION",                                     "type": "text" },
                { "key": "language",      "value": "ENGLISH",                                        "type": "text" }
              ]
            }
          }
        },
        {
          "name": "Add same title again (expect 409 duplicate)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{gatewayUrl}}/api/books/addTitle", "host": ["{{gatewayUrl}}"], "path": ["api","books","addTitle"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{staffToken}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title",         "value": "{{testBookTitle}}",                              "type": "text" },
                { "key": "author",        "value": "E2E Test Author",                                "type": "text" },
                { "key": "description",   "value": "A test book for end-to-end automated testing.", "type": "text" },
                { "key": "yearPublished", "value": "2024",                                           "type": "text" },
                { "key": "genre",         "value": "NONFICTION",                                     "type": "text" },
                { "key": "language",      "value": "ENGLISH",                                        "type": "text" }
              ]
            }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Duplicate title returns 409', function () { pm.response.to.have.status(409); });",
            "const body = pm.response.json();",
            "pm.test('Error message is present', function () { pm.expect(body).to.have.property('error'); });",
            "pm.test('existingId is returned in conflict response', function () {",
            "    pm.expect(body).to.have.property('existingId');",
            "    pm.expect(String(body.existingId)).to.equal(pm.collectionVariables.get('testBookId'));",
            "});"
          ]}}]
        }
      ]
    },

