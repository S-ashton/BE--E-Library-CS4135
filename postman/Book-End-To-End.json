    {
      "name": "5 - Get Title",
      "item": [
        {
          "name": "Get title by ID (USER)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{gatewayUrl}}/api/books/{{testBookId}}",
              "host": ["{{gatewayUrl}}"], "path": ["api","books","{{testBookId}}"]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Get title returns 201', function () { pm.response.to.have.status(201); });",
            "const body = pm.response.json();",
            "pm.test('Response id matches', function () {",
            "    pm.expect(String(body.id)).to.equal(pm.collectionVariables.get('testBookId'));",
            "});",
            "pm.test('Response title matches', function () {",
            "    pm.expect(body.title).to.equal(pm.collectionVariables.get('testBookTitle'));",
            "});",
            "pm.test('Response has all required fields', function () {",
            "    pm.expect(body).to.have.property('id');",
            "    pm.expect(body).to.have.property('title');",
            "    pm.expect(body).to.have.property('author');",
            "    pm.expect(body).to.have.property('description');",
            "    pm.expect(body).to.have.property('yearPublished');",
            "    pm.expect(body).to.have.property('genre');",
            "    pm.expect(body).to.have.property('language');",
            "    pm.expect(body).to.have.property('copiesAvailable');",
            "});",
            "pm.test('copiesAvailable is a number', function () {",
            "    pm.expect(body.copiesAvailable).to.be.a('number');",
            "});"
          ]}}]
        },
        {
          "name": "Get title by ID (STAFF)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{gatewayUrl}}/api/books/{{testBookId}}",
              "host": ["{{gatewayUrl}}"], "path": ["api","books","{{testBookId}}"]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{staffToken}}" }]
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('STAFF can get title (201)', function () { pm.response.to.have.status(201); });",
            "pm.test('Response id matches', function () {",
            "    pm.expect(String(pm.response.json().id)).to.equal(pm.collectionVariables.get('testBookId'));",
            "});"
          ]}}]
        },
