    {
      "name": "6 - Search",
      "item": [
        {
          "name": "Search by keyword (finds our test book)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{gatewayUrl}}/api/books/search?keyword=E2E-Book-Test",
              "host": ["{{gatewayUrl}}"], "path": ["api","books","search"],
              "query": [{ "key": "keyword", "value": "E2E-Book-Test" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Search returns 200', function () { pm.response.to.have.status(200); });",
            "const body = pm.response.json();",
            "pm.test('Search result is an array', function () { pm.expect(body).to.be.an('array'); });",
            "pm.test('Search finds our test book', function () {",
            "    const ids = body.map(b => String(b.id));",
            "    pm.expect(ids).to.include(pm.collectionVariables.get('testBookId'));",
            "});",
            "pm.test('Each result has required fields', function () {",
            "    body.forEach(function(b) {",
            "        pm.expect(b).to.have.property('id');",
            "        pm.expect(b).to.have.property('title');",
            "        pm.expect(b).to.have.property('author');",
            "        pm.expect(b).to.have.property('genre');",
            "        pm.expect(b).to.have.property('language');",
            "    });",
            "});"
          ]}}]
        },
        {
          "name": "Search by genre NONFICTION",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{gatewayUrl}}/api/books/search?genre=NONFICTION",
              "host": ["{{gatewayUrl}}"], "path": ["api","books","search"],
              "query": [{ "key": "genre", "value": "NONFICTION" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Genre search returns 200', function () { pm.response.to.have.status(200); });",
            "const body = pm.response.json();",
            "pm.test('Genre search result is an array', function () { pm.expect(body).to.be.an('array'); });",
            "pm.test('All results have genre NONFICTION', function () {",
            "    body.forEach(function(b) {",
            "        pm.expect(b.genre).to.equal('NONFICTION');",
            "    });",
            "});",
            "pm.test('Our test book appears in NONFICTION results', function () {",
            "    const ids = body.map(b => String(b.id));",
            "    pm.expect(ids).to.include(pm.collectionVariables.get('testBookId'));",
            "});"
          ]}}]
        },
        {
          "name": "Search by language ENGLISH",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{gatewayUrl}}/api/books/search?language=ENGLISH",
              "host": ["{{gatewayUrl}}"], "path": ["api","books","search"],
              "query": [{ "key": "language", "value": "ENGLISH" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Language search returns 200', function () { pm.response.to.have.status(200); });",
            "const body = pm.response.json();",
            "pm.test('Language search result is an array', function () { pm.expect(body).to.be.an('array'); });",
            "pm.test('All results have language ENGLISH', function () {",
            "    body.forEach(function(b) { pm.expect(b.language).to.equal('ENGLISH'); });",
            "});",
