{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "Gateway End-To-End",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "gatewayUrl",   "value": "http://localhost:8080", "type": "string" },
    { "key": "testPassword", "value": "Test@12345", "type": "string" },
    { "key": "userToken",    "value": "", "type": "string" },
    { "key": "adminToken",   "value": "", "type": "string" }
  ],
  "item": [

    {
      "name": "1 - Setup",
      "item": [
        {
          "name": "Register gateway-test USER (201 or 409)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{gatewayUrl}}/api/auth/register", "host": ["{{gatewayUrl}}"], "path": ["api","auth","register"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"gw-e2e-user@elibrary.ie\",\n  \"password\": \"{{testPassword}}\",\n  \"role\": \"USER\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('USER account ready (201 or 409)', function () {",
            "    pm.expect(pm.response.code).to.be.oneOf([201, 409]);",
            "});"
          ]}}]
        },
        {
          "name": "Register gateway-test ADMIN (201 or 409)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{gatewayUrl}}/api/auth/register", "host": ["{{gatewayUrl}}"], "path": ["api","auth","register"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"gw-e2e-admin@elibrary.ie\",\n  \"password\": \"{{testPassword}}\",\n  \"role\": \"ADMIN\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('ADMIN account ready (201 or 409)', function () {",
            "    pm.expect(pm.response.code).to.be.oneOf([201, 409]);",
            "});"
          ]}}]
        },
        {
          "name": "Login as gateway-test USER",
          "request": {
            "method": "POST",
            "url": { "raw": "{{gatewayUrl}}/api/auth/login", "host": ["{{gatewayUrl}}"], "path": ["api","auth","login"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"gw-e2e-user@elibrary.ie\",\n  \"password\": \"{{testPassword}}\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('USER login returns 200', function () { pm.response.to.have.status(200); });",
            "pm.collectionVariables.set('userToken', pm.response.json().token);"
          ]}}]
        },
        {
          "name": "Login as gateway-test ADMIN",
          "request": {
            "method": "POST",
            "url": { "raw": "{{gatewayUrl}}/api/auth/login", "host": ["{{gatewayUrl}}"], "path": ["api","auth","login"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"gw-e2e-admin@elibrary.ie\",\n  \"password\": \"{{testPassword}}\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('ADMIN login returns 200', function () { pm.response.to.have.status(200); });",
            "pm.collectionVariables.set('adminToken', pm.response.json().token);"
          ]}}]
        }
      ]
    },

    {
      "name": "2 - Public Routes (no JWT required)",
      "item": [
        {
          "name": "Actuator health is accessible without JWT",
          "request": {
            "method": "GET",
            "url": { "raw": "{{gatewayUrl}}/actuator/health", "host": ["{{gatewayUrl}}"], "path": ["actuator","health"] },
            "header": []
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('/actuator/health returns 200 without JWT', function () { pm.response.to.have.status(200); });",
            "pm.test('Health response is JSON (actuator media type)', function () {",
            "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/vnd.spring-boot.actuator');",
            "});",
            "pm.test('Health response has status field', function () {",
            "    pm.expect(pm.response.json()).to.have.property('status');",
            "});"
          ]}}]
        },
        {
          "name": "Actuator gateway routes accessible without JWT",
          "request": {
            "method": "GET",
            "url": { "raw": "{{gatewayUrl}}/actuator/gateway/routes", "host": ["{{gatewayUrl}}"], "path": ["actuator","gateway","routes"] },
            "header": []
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('/actuator/gateway/routes returns 200 without JWT', function () { pm.response.to.have.status(200); });",
            "const body = pm.response.json();",
            "pm.test('Routes response is an array', function () { pm.expect(body).to.be.an('array'); });",
            "pm.test('All 4 service routes are registered', function () {",
            "    pm.expect(body.length).to.be.at.least(4);",
            "});",
            "pm.test('user-service route is present', function () {",
            "    pm.expect(body.some(r => r.route_id === 'user-service')).to.be.true;",
            "});",
            "pm.test('book-service route is present', function () {",
            "    pm.expect(body.some(r => r.route_id === 'book-service')).to.be.true;",
            "});",
            "pm.test('loan-service route is present', function () {",
            "    pm.expect(body.some(r => r.route_id === 'loan-service')).to.be.true;",
            "});",
            "pm.test('recommendation-service route is present', function () {",
            "    pm.expect(body.some(r => r.route_id === 'recommendation-service')).to.be.true;",
            "});"
          ]}}]
        },
        {
          "name": "OpenAPI spec accessible without JWT",
          "request": {
            "method": "GET",
            "url": { "raw": "{{gatewayUrl}}/v3/api-docs", "host": ["{{gatewayUrl}}"], "path": ["v3","api-docs"] },
            "header": []
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('/v3/api-docs returns 200 without JWT', function () { pm.response.to.have.status(200); });",
            "pm.test('Spec is JSON', function () {",
            "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
            "});"
          ]}}]
        },
        {
          "name": "Auth register endpoint is public (no JWT gate)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{gatewayUrl}}/api/auth/register", "host": ["{{gatewayUrl}}"], "path": ["api","auth","register"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"gw-public-test@elibrary.ie\",\n  \"password\": \"{{testPassword}}\",\n  \"role\": \"USER\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Auth register passes gateway without JWT (201 or 409)', function () {",
            "    pm.expect(pm.response.code).to.be.oneOf([201, 409]);",
            "});",
            "pm.test('Response is NOT a gateway 401', function () {",
            "    pm.expect(pm.response.code).to.not.equal(401);",
            "});"
          ]}}]
        },
        {
          "name": "Auth login endpoint is public (no JWT gate)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{gatewayUrl}}/api/auth/login", "host": ["{{gatewayUrl}}"], "path": ["api","auth","login"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"gw-public-test@elibrary.ie\",\n  \"password\": \"{{testPassword}}\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Auth login passes gateway without JWT (200 or 401)', function () {",
            "    pm.expect(pm.response.code).to.be.oneOf([200, 401]);",
            "});",
            "pm.test('Response is NOT a gateway-level 401 with Unauthorized error', function () {",
            "    if (pm.response.code === 401) {",
            "        const body = pm.response.json();",
            "        pm.expect(body.message).to.not.equal('Authentication token is required');",
            "    }",
            "});"
          ]}}]
        }
      ]
    },

    {
      "name": "3 - JWT Filter - Authentication Rejections",
      "item": [
        {
          "name": "No Authorization header (expect 401)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{gatewayUrl}}/api/users/me", "host": ["{{gatewayUrl}}"], "path": ["api","users","me"] },
            "header": []
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('No token returns 401', function () { pm.response.to.have.status(401); });",
            "const body = pm.response.json();",
            "pm.test('Message is Authentication token is required', function () {",
            "    pm.expect(body.message).to.equal('Authentication token is required');",
            "});",
            "pm.test('Error is Unauthorized', function () {",
            "    pm.expect(body.error).to.equal('Unauthorized');",
            "});",
            "pm.test('Status field is 401', function () { pm.expect(body.status).to.equal(401); });",
            "pm.test('Timestamp field present', function () { pm.expect(body).to.have.property('timestamp'); });",
            "pm.test('Response Content-Type is JSON', function () {",
            "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
            "});"
          ]}}]
        },
        {
          "name": "Non-Bearer scheme (Basic auth header) (expect 401)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{gatewayUrl}}/api/users/me", "host": ["{{gatewayUrl}}"], "path": ["api","users","me"] },
            "header": [{ "key": "Authorization", "value": "Basic dXNlcjpwYXNz" }]
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Non-Bearer scheme returns 401', function () { pm.response.to.have.status(401); });",
            "pm.test('Message is Invalid authentication token', function () {",
            "    pm.expect(pm.response.json().message).to.equal('Invalid authentication token');",
            "});"
          ]}}]
        },
        {
          "name": "Bearer with empty token value (expect 401)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{gatewayUrl}}/api/users/me", "host": ["{{gatewayUrl}}"], "path": ["api","users","me"] },
            "header": [{ "key": "Authorization", "value": "Bearer " }]
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Empty Bearer value returns 401', function () { pm.response.to.have.status(401); });",
            "pm.test('Message is Invalid authentication token', function () {",
            "    pm.expect(pm.response.json().message).to.equal('Invalid authentication token');",
            "});"
          ]}}]
        },
        {
          "name": "Bearer with random non-JWT string (expect 401)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{gatewayUrl}}/api/users/me", "host": ["{{gatewayUrl}}"], "path": ["api","users","me"] },
            "header": [{ "key": "Authorization", "value": "Bearer notajwttoken" }]
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Non-JWT string returns 401', function () { pm.response.to.have.status(401); });",
            "pm.test('Message is Invalid authentication token', function () {",
            "    pm.expect(pm.response.json().message).to.equal('Invalid authentication token');",
            "});"
          ]}}]
        },
        {
          "name": "Structurally valid JWT with wrong signature (expect 401)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{gatewayUrl}}/api/users/me", "host": ["{{gatewayUrl}}"], "path": ["api","users","me"] },
            "header": [{ "key": "Authorization", "value": "Bearer eyJhbGciOiJIUzUxMiJ9.eyJzdWIiOiJoYWNrZXJAZXZpbC5jb20iLCJyb2xlIjoiQURNSU4iLCJ1c2VySWQiOjF9.INVALIDSIGNATUREXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX" }]
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('JWT with wrong signature returns 401', function () { pm.response.to.have.status(401); });",
            "pm.test('Message is Invalid authentication token', function () {",
            "    pm.expect(pm.response.json().message).to.equal('Invalid authentication token');",
            "});"
          ]}}]
        },
        {
          "name": "JWT on a different protected route also enforced (expect 401)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{gatewayUrl}}/api/loans/history", "host": ["{{gatewayUrl}}"], "path": ["api","loans","history"] },
            "header": []
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('No token on /api/loans/history returns 401', function () { pm.response.to.have.status(401); });",
            "pm.test('Message is Authentication token is required', function () {",
            "    pm.expect(pm.response.json().message).to.equal('Authentication token is required');",
            "});"
          ]}}]
        }
      ]
    },

    {
      "name": "4 - JWT Filter - Valid Token Forwarding",
      "item": [
        {
          "name": "Valid USER JWT passes gateway to user-service",
          "request": {
            "method": "GET",
            "url": { "raw": "{{gatewayUrl}}/api/users/me", "host": ["{{gatewayUrl}}"], "path": ["api","users","me"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Valid USER JWT is forwarded by gateway (200 from user-service)', function () {",
            "    pm.response.to.have.status(200);",
            "});",
            "const body = pm.response.json();",
            "pm.test('Downstream received identity (profile has email)', function () {",
            "    pm.expect(body).to.have.property('email');",
            "    pm.expect(body.email).to.equal('gw-e2e-user@elibrary.ie');",
            "});",
            "pm.test('Downstream received role claim (USER)', function () {",
            "    pm.expect(body.role).to.equal('USER');",
            "});"
          ]}}]
        },
        {
          "name": "Valid ADMIN JWT passes gateway to user-service",
          "request": {
            "method": "GET",
            "url": { "raw": "{{gatewayUrl}}/api/users/me", "host": ["{{gatewayUrl}}"], "path": ["api","users","me"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Valid ADMIN JWT is forwarded by gateway (200 from user-service)', function () {",
            "    pm.response.to.have.status(200);",
            "});",
            "pm.test('Downstream received ADMIN role', function () {",
            "    pm.expect(pm.response.json().role).to.equal('ADMIN');",
            "});"
          ]}}]
        },
        {
          "name": "Gateway strips forged X-Authenticated-User header (no JWT → still 401)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{gatewayUrl}}/api/users/me", "host": ["{{gatewayUrl}}"], "path": ["api","users","me"] },
            "header": [
              { "key": "X-Authenticated-User",    "value": "hacker@evil.com" },
              { "key": "X-Authenticated-Role",    "value": "ADMIN" },
              { "key": "X-Authenticated-User-Id", "value": "1" }
            ]
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Forged identity headers without JWT still returns 401', function () {",
            "    pm.response.to.have.status(401);",
            "});",
            "pm.test('Message is Authentication token is required (not bypassed by forged header)', function () {",
            "    pm.expect(pm.response.json().message).to.equal('Authentication token is required');",
            "});"
          ]}}]
        },
        {
          "name": "Gateway replaces forged X-Authenticated-User header when JWT is valid",
          "request": {
            "method": "GET",
            "url": { "raw": "{{gatewayUrl}}/api/users/me", "host": ["{{gatewayUrl}}"], "path": ["api","users","me"] },
            "header": [
              { "key": "Authorization",           "value": "Bearer {{userToken}}" },
              { "key": "X-Authenticated-User",    "value": "hacker@evil.com" },
              { "key": "X-Authenticated-Role",    "value": "ADMIN" },
              { "key": "X-Authenticated-User-Id", "value": "99999" }
            ]
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Request with valid JWT and forged header returns 200', function () {",
            "    pm.response.to.have.status(200);",
            "});",
            "pm.test('Gateway overwrote forged identity — email is from JWT not forged header', function () {",
            "    pm.expect(pm.response.json().email).to.equal('gw-e2e-user@elibrary.ie');",
            "    pm.expect(pm.response.json().email).to.not.equal('hacker@evil.com');",
            "});",
            "pm.test('Role is USER from JWT, not forged ADMIN', function () {",
            "    pm.expect(pm.response.json().role).to.equal('USER');",
            "});"
          ]}}]
        }
      ]
    },

