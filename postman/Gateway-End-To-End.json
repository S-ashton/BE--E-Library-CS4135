    {
      "name": "6 - Gateway Error Responses",
      "item": [
        {
          "name": "Unknown route with valid JWT returns gateway 404",
          "request": {
            "method": "GET",
            "url": { "raw": "{{gatewayUrl}}/api/nonexistent/path/xyz", "host": ["{{gatewayUrl}}"], "path": ["api","nonexistent","path","xyz"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Unknown route returns 404', function () { pm.response.to.have.status(404); });",
            "const body = pm.response.json();",
            "pm.test('404 message is Route not found', function () {",
            "    pm.expect(body.message).to.equal('Route not found');",
            "});",
            "pm.test('404 response has timestamp', function () { pm.expect(body).to.have.property('timestamp'); });",
            "pm.test('404 response has status field = 404', function () { pm.expect(body.status).to.equal(404); });",
            "pm.test('404 response has error field', function () { pm.expect(body).to.have.property('error'); });",
            "pm.test('404 response has path field', function () {",
            "    pm.expect(body).to.have.property('path');",
            "    pm.expect(body.path).to.include('nonexistent');",
            "});",
            "pm.test('404 response has requestId field', function () {",
            "    pm.expect(body).to.have.property('requestId');",
            "    pm.expect(body.requestId).to.be.a('string').and.not.be.empty;",
            "});"
          ]}}]
        },
        {
          "name": "Unknown route without JWT returns 404 (no route matched, filter skipped)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{gatewayUrl}}/api/nonexistent/path/xyz", "host": ["{{gatewayUrl}}"], "path": ["api","nonexistent","path","xyz"] },
            "header": []
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Unknown route without JWT returns 404 (GlobalFilter only runs on matched routes)', function () {",
            "    pm.response.to.have.status(404);",
            "});",
            "pm.test('Message is Route not found', function () {",
            "    pm.expect(pm.response.json().message).to.equal('Route not found');",
            "});"
          ]}}]
        },
        {
          "name": "Gateway 401 error shape validation",
          "request": {
            "method": "GET",
            "url": { "raw": "{{gatewayUrl}}/api/loans/history", "host": ["{{gatewayUrl}}"], "path": ["api","loans","history"] },
            "header": []
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Gateway 401 returns 401', function () { pm.response.to.have.status(401); });",
            "const body = pm.response.json();",
            "pm.test('401 body has timestamp (ISO string)', function () {",
            "    pm.expect(body).to.have.property('timestamp');",
            "    pm.expect(body.timestamp).to.be.a('string');",
            "    pm.expect(isNaN(Date.parse(body.timestamp))).to.be.false;",
            "});",
            "pm.test('401 body has status = 401', function () { pm.expect(body.status).to.equal(401); });",
            "pm.test('401 body has error = Unauthorized', function () { pm.expect(body.error).to.equal('Unauthorized'); });",
            "pm.test('401 body has message', function () { pm.expect(body).to.have.property('message'); });",
            "pm.test('Password/token/secret NOT leaked in 401 body', function () {",
            "    const raw = pm.response.text();",
            "    pm.expect(raw).to.not.include('secret');",
            "    pm.expect(raw).to.not.include('password');",
            "});"
          ]}}]
        }
      ]
    },

    {
      "name": "7 - CORS Preflight",
      "item": [
        {
          "name": "OPTIONS preflight on protected route is passed through",
          "request": {
            "method": "OPTIONS",
            "url": { "raw": "{{gatewayUrl}}/api/users/me", "host": ["{{gatewayUrl}}"], "path": ["api","users","me"] },
            "header": [
              { "key": "Origin",                         "value": "http://localhost:5173" },
              { "key": "Access-Control-Request-Method",  "value": "GET" },
              { "key": "Access-Control-Request-Headers", "value": "Authorization" }
            ]
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('OPTIONS preflight returns 200 (not blocked by auth filter)', function () {",
            "    pm.expect(pm.response.code).to.be.oneOf([200, 204]);",
            "});",
            "pm.test('CORS Allow-Origin header present', function () {",
            "    const acao = pm.response.headers.get('Access-Control-Allow-Origin');",
            "    pm.expect(acao).to.not.be.null;",
            "    pm.expect(acao).to.equal('http://localhost:5173');",
            "});",
            "pm.test('CORS Allow-Methods header present', function () {",
            "    pm.expect(pm.response.headers.get('Access-Control-Allow-Methods')).to.not.be.null;",
            "});",
            "pm.test('CORS Allow-Credentials is true', function () {",
            "    pm.expect(pm.response.headers.get('Access-Control-Allow-Credentials')).to.equal('true');",
            "});"
          ]}}]
        },
        {
          "name": "OPTIONS preflight on public auth route is also allowed",
          "request": {
            "method": "OPTIONS",
            "url": { "raw": "{{gatewayUrl}}/api/auth/login", "host": ["{{gatewayUrl}}"], "path": ["api","auth","login"] },
            "header": [
              { "key": "Origin",                         "value": "http://localhost:5173" },
              { "key": "Access-Control-Request-Method",  "value": "POST" },
              { "key": "Access-Control-Request-Headers", "value": "Content-Type" }
            ]
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('OPTIONS on /api/auth/login returns 200/204', function () {",
            "    pm.expect(pm.response.code).to.be.oneOf([200, 204]);",
            "});",
            "pm.test('CORS Allow-Origin present on auth route', function () {",
            "    pm.expect(pm.response.headers.get('Access-Control-Allow-Origin')).to.not.be.null;",
            "});"
          ]}}]
        }
      ]
    }

  ]
}
