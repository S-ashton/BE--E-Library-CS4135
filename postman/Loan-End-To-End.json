{
  "info": {
    "_postman_id": "b2c3d4e5-f6a7-8901-bcde-f12345678901",
    "name": "Loan End-To-End",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "gatewayUrl",  "value": "http://localhost:8080", "type": "string" },
    { "key": "userToken",   "value": "", "type": "string" },
    { "key": "staffToken",  "value": "", "type": "string" },
    { "key": "userId",      "value": "", "type": "string" },
    { "key": "bookId",      "value": "1",  "type": "string" },
    { "key": "loanId",      "value": "", "type": "string" },
    { "key": "copyId",      "value": "", "type": "string" }
  ],
  "item": [

    {
      "name": "1 - Auth Setup",
      "item": [
        {
          "name": "Register USER account",
          "request": {
            "method": "POST",
            "url": { "raw": "{{gatewayUrl}}/api/auth/register", "host": ["{{gatewayUrl}}"], "path": ["api","auth","register"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"loan-user@elibrary.ie\",\n  \"password\": \"Test@12345\",\n  \"role\": \"USER\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('USER account ready (201 or 409)', function () {",
            "    pm.expect(pm.response.code).to.be.oneOf([201, 409]);",
            "});"
          ]}}]
        },
        {
          "name": "Register STAFF account",
          "request": {
            "method": "POST",
            "url": { "raw": "{{gatewayUrl}}/api/auth/register", "host": ["{{gatewayUrl}}"], "path": ["api","auth","register"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"loan-staff@elibrary.ie\",\n  \"password\": \"Test@12345\",\n  \"role\": \"STAFF\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('STAFF account ready (201 or 409)', function () {",
            "    pm.expect(pm.response.code).to.be.oneOf([201, 409]);",
            "});"
          ]}}]
        },
        {
          "name": "Login as USER",
          "request": {
            "method": "POST",
            "url": { "raw": "{{gatewayUrl}}/api/auth/login", "host": ["{{gatewayUrl}}"], "path": ["api","auth","login"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"loan-user@elibrary.ie\",\n  \"password\": \"Test@12345\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('USER login returns 200', function () { pm.response.to.have.status(200); });",
            "const body = pm.response.json();",
            "pm.test('Access token present', function () { pm.expect(body).to.have.property('token'); });",
            "pm.collectionVariables.set('userToken', body.token);"
          ]}}]
        },
        {
          "name": "Login as STAFF",
          "request": {
            "method": "POST",
            "url": { "raw": "{{gatewayUrl}}/api/auth/login", "host": ["{{gatewayUrl}}"], "path": ["api","auth","login"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"loan-staff@elibrary.ie\",\n  \"password\": \"Test@12345\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('STAFF login returns 200', function () { pm.response.to.have.status(200); });",
            "const body = pm.response.json();",
            "pm.test('Access token present', function () { pm.expect(body).to.have.property('token'); });",
            "pm.collectionVariables.set('staffToken', body.token);"
          ]}}]
        },
        {
          "name": "Get USER profile (capture userId)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{gatewayUrl}}/api/users/me", "host": ["{{gatewayUrl}}"], "path": ["api","users","me"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Profile returns 200', function () { pm.response.to.have.status(200); });",
            "const body = pm.response.json();",
            "pm.test('Profile has id and email', function () {",
            "    pm.expect(body).to.have.property('id');",
            "    pm.expect(body).to.have.property('email');",
            "});",
            "pm.collectionVariables.set('userId', String(body.id));",
            "console.log('Captured userId:', body.id);"
          ]}}]
        }
      ]
    },

    {
      "name": "2 - Gateway Auth Enforcement",
      "item": [
        {
          "name": "Borrow without auth token (expect 401)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{gatewayUrl}}/api/loans", "host": ["{{gatewayUrl}}"], "path": ["api","loans"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"bookId\": 1,\n  \"email\": \"loan-user@elibrary.ie\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Missing token is rejected with 401', function () { pm.response.to.have.status(401); });"
          ]}}]
        },
        {
          "name": "Borrow with malformed token (expect 401)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{gatewayUrl}}/api/loans", "host": ["{{gatewayUrl}}"], "path": ["api","loans"] },
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer not.a.valid.token" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"bookId\": 1,\n  \"email\": \"loan-user@elibrary.ie\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Malformed token is rejected with 401', function () { pm.response.to.have.status(401); });"
          ]}}]
        },
        {
          "name": "Get loan history without auth token (expect 401)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{gatewayUrl}}/api/loans/history", "host": ["{{gatewayUrl}}"], "path": ["api","loans","history"] },
            "header": []
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('History without token is rejected with 401', function () { pm.response.to.have.status(401); });"
          ]}}]
        }
      ]
    },

    {
      "name": "3 - Input Validation",
      "item": [
        {
          "name": "Borrow with missing bookId (expect 400)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{gatewayUrl}}/api/loans", "host": ["{{gatewayUrl}}"], "path": ["api","loans"] },
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"loan-user@elibrary.ie\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Missing bookId returns 400', function () { pm.response.to.have.status(400); });"
          ]}}]
        },
        {
          "name": "Borrow with missing email (expect 400)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{gatewayUrl}}/api/loans", "host": ["{{gatewayUrl}}"], "path": ["api","loans"] },
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"bookId\": 1\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Missing email returns 400', function () { pm.response.to.have.status(400); });"
          ]}}]
        },
        {
          "name": "Borrow with invalid email format (expect 400)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{gatewayUrl}}/api/loans", "host": ["{{gatewayUrl}}"], "path": ["api","loans"] },
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"bookId\": 1,\n  \"email\": \"not-an-email\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Invalid email format returns 400', function () { pm.response.to.have.status(400); });"
          ]}}]
        },
        {
          "name": "Return non-existent loan UUID (expect 404)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{gatewayUrl}}/api/loans/00000000-0000-0000-0000-000000000000/return",
              "host": ["{{gatewayUrl}}"], "path": ["api","loans","00000000-0000-0000-0000-000000000000","return"]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Unknown loan UUID returns 404', function () { pm.response.to.have.status(404); });",
            "pm.test('Error body has error field', function () {",
            "    pm.expect(pm.response.json()).to.have.property('error');",
            "});"
          ]}}]
        }
      ]
    },

    {
      "name": "4 - Book Unavailability (Book-Service Integration)",
      "item": [
        {
          "name": "Borrow non-existent book title (expect 409 - no copies available)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{gatewayUrl}}/api/loans", "host": ["{{gatewayUrl}}"], "path": ["api","loans"] },
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"bookId\": 999999,\n  \"email\": \"loan-user@elibrary.ie\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Non-existent book returns 409 (unavailable / no copies)', function () { pm.response.to.have.status(409); });",
            "pm.test('Error message present', function () {",
            "    pm.expect(pm.response.json()).to.have.property('error');",
            "});"
          ]}}]
        }
      ]
    },

    {
      "name": "5 - Borrow Flow",
      "item": [
        {
          "name": "Ensure available copy exists (add copy via book-service)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{gatewayUrl}}/api/books/addCopy?titleId={{bookId}}",
              "host": ["{{gatewayUrl}}"], "path": ["api","books","addCopy"],
              "query": [{ "key": "titleId", "value": "{{bookId}}" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{staffToken}}" }]
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Add copy returns 201', function () { pm.response.to.have.status(201); });",
            "const body = pm.response.json();",
            "pm.test('Copy has an id', function () { pm.expect(body).to.have.property('id'); });",
            "pm.collectionVariables.set('copyId', String(body.id));",
            "console.log('Available copy created, copyId:', body.id);"
          ]}}]
        },
        {
          "name": "Borrow a book (USER)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{gatewayUrl}}/api/loans", "host": ["{{gatewayUrl}}"], "path": ["api","loans"] },
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"bookId\": {{bookId}},\n  \"email\": \"loan-user@elibrary.ie\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Borrow returns 201', function () { pm.response.to.have.status(201); });",
            "const body = pm.response.json();",
            "pm.test('Loan has id (UUID)', function () {",
            "    pm.expect(body).to.have.property('id');",
            "    pm.expect(body.id).to.match(/^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i);",
            "});",
            "pm.test('Loan has ACTIVE status', function () { pm.expect(body.status).to.equal('ACTIVE'); });",
            "pm.test('Loan userId matches authenticated user', function () {",
            "    pm.expect(String(body.userId)).to.equal(pm.collectionVariables.get('userId'));",
            "});",
            "pm.test('Loan bookId matches requested book', function () {",
            "    pm.expect(String(body.bookId)).to.equal(pm.collectionVariables.get('bookId'));",
            "});",
            "pm.test('Loan has borrowDate', function () { pm.expect(body).to.have.property('borrowDate'); });",
            "pm.test('Loan has dueDate 14 days from now', function () {",
            "    const borrow = new Date(body.borrowDate);",
            "    const due = new Date(body.dueDate);",
            "    const diffDays = Math.round((due - borrow) / (1000 * 60 * 60 * 24));",
            "    pm.expect(diffDays).to.equal(14);",
            "});",
            "pm.test('Loan fineAmount is 0', function () {",
            "    pm.expect(Number(body.fineAmount)).to.equal(0);",
            "});",
            "pm.collectionVariables.set('loanId', body.id);",
            "console.log('Borrow successful, loanId:', body.id);"
          ]}}]
        },
        {
          "name": "Verify copy status changed to ON_LOAN (book-service integration)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{gatewayUrl}}/api/books/getAvailableCopy?bookId={{bookId}}",
              "host": ["{{gatewayUrl}}"], "path": ["api","books","getAvailableCopy"],
              "query": [{ "key": "bookId", "value": "{{bookId}}" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const code = pm.response.code;",
            "pm.test('After borrow, no available copy OR a different copy is available (not ON_LOAN)', function () {",
            "    pm.expect(code).to.be.oneOf([200, 409]);",
            "    if (code === 200) {",
            "        const body = pm.response.json();",
            "        pm.expect(body.status).to.equal('AVAILABLE');",
            "        pm.expect(String(body.id)).to.not.equal(pm.collectionVariables.get('copyId'));",
            "    }",
            "});"
          ]}}]
        }
      ]
    },

    {
      "name": "6 - Duplicate Borrow Prevention",
      "item": [
        {
          "name": "Borrow same book again (expect 409)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{gatewayUrl}}/api/loans", "host": ["{{gatewayUrl}}"], "path": ["api","loans"] },
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"bookId\": {{bookId}},\n  \"email\": \"loan-user@elibrary.ie\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Duplicate borrow returns 409', function () { pm.response.to.have.status(409); });",
            "pm.test('Error message references active or overdue loan', function () {",
            "    const body = pm.response.json();",
            "    pm.expect(body).to.have.property('error');",
            "    pm.expect(body.error.toLowerCase()).to.include('loan');",
            "});"
          ]}}]
        }
      ]
    },

    {
      "name": "7 - Loan History",
      "item": [
        {
          "name": "Get loan history (USER)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{gatewayUrl}}/api/loans/history", "host": ["{{gatewayUrl}}"], "path": ["api","loans","history"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('History returns 200', function () { pm.response.to.have.status(200); });",
            "const body = pm.response.json();",
            "pm.test('History is an array', function () { pm.expect(body).to.be.an('array'); });",
            "pm.test('History contains at least one loan', function () { pm.expect(body.length).to.be.greaterThan(0); });",
            "const loan = body[0];",
            "pm.test('Most recent loan has expected fields', function () {",
            "    pm.expect(loan).to.have.property('id');",
            "    pm.expect(loan).to.have.property('userId');",
            "    pm.expect(loan).to.have.property('bookId');",
            "    pm.expect(loan).to.have.property('copyId');",
            "    pm.expect(loan).to.have.property('status');",
            "    pm.expect(loan).to.have.property('borrowDate');",
            "    pm.expect(loan).to.have.property('dueDate');",
            "    pm.expect(loan).to.have.property('fineAmount');",
            "});",
            "pm.test('Most recent loan belongs to this user', function () {",
            "    pm.expect(String(loan.userId)).to.equal(pm.collectionVariables.get('userId'));",
            "});",
            "pm.test('Active loan appears in history', function () {",
            "    const ids = body.map(l => l.id);",
            "    pm.expect(ids).to.include(pm.collectionVariables.get('loanId'));",
            "});",
            "pm.test('History ordered newest first (borrowDate desc)', function () {",
            "    if (body.length > 1) {",
            "        const d1 = new Date(body[0].borrowDate);",
            "        const d2 = new Date(body[1].borrowDate);",
            "        pm.expect(d1.getTime()).to.be.at.least(d2.getTime());",
            "    }",
            "});"
          ]}}]
        },
        {
          "name": "STAFF token also gets own history",
          "request": {
            "method": "GET",
            "url": { "raw": "{{gatewayUrl}}/api/loans/history", "host": ["{{gatewayUrl}}"], "path": ["api","loans","history"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{staffToken}}" }]
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('STAFF can view their own history (200)', function () { pm.response.to.have.status(200); });",
            "pm.test('STAFF history is an array', function () { pm.expect(pm.response.json()).to.be.an('array'); });"
          ]}}]
        }
      ]
    },

    {
      "name": "8 - Return Flow",
      "item": [
        {
          "name": "Return the borrowed book (USER)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{gatewayUrl}}/api/loans/{{loanId}}/return",
              "host": ["{{gatewayUrl}}"], "path": ["api","loans","{{loanId}}","return"]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Return returns 200', function () { pm.response.to.have.status(200); });",
            "const body = pm.response.json();",
            "pm.test('Loan status is RETURNED', function () { pm.expect(body.status).to.equal('RETURNED'); });",
            "pm.test('returnDate is set', function () {",
            "    pm.expect(body).to.have.property('returnDate');",
            "    pm.expect(body.returnDate).to.not.be.null;",
            "});",
            "pm.test('fineAmount is a number', function () {",
            "    pm.expect(Number(body.fineAmount)).to.be.a('number');",
            "    pm.expect(Number(body.fineAmount)).to.be.at.least(0);",
            "});",
            "pm.test('Loan id matches returned loan', function () {",
            "    pm.expect(body.id).to.equal(pm.collectionVariables.get('loanId'));",
            "});",
            "console.log('Return successful, fineAmount:', body.fineAmount);"
          ]}}]
        },
        {
          "name": "Verify copy restored to AVAILABLE after return (book-service integration)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{gatewayUrl}}/api/books/getAvailableCopy?bookId={{bookId}}",
              "host": ["{{gatewayUrl}}"], "path": ["api","books","getAvailableCopy"],
              "query": [{ "key": "bookId", "value": "{{bookId}}" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('After return, an available copy exists (book-service updated)', function () {",
            "    pm.response.to.have.status(200);",
            "});",
            "pm.test('Available copy status is AVAILABLE', function () {",
            "    pm.expect(pm.response.json().status).to.equal('AVAILABLE');",
            "});"
          ]}}]
        },
        {
          "name": "Return same loan again (expect 409)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{gatewayUrl}}/api/loans/{{loanId}}/return",
              "host": ["{{gatewayUrl}}"], "path": ["api","loans","{{loanId}}","return"]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Double return returns 409', function () { pm.response.to.have.status(409); });",
            "pm.test('Error message references already returned', function () {",
            "    const body = pm.response.json();",
            "    pm.expect(body).to.have.property('error');",
            "    pm.expect(body.error.toLowerCase()).to.include('return');",
            "});"
          ]}}]
        }
      ]
    },

    {
      "name": "9 - Post-Return History",
      "item": [
        {
          "name": "History shows RETURNED status after return",
          "request": {
            "method": "GET",
            "url": { "raw": "{{gatewayUrl}}/api/loans/history", "host": ["{{gatewayUrl}}"], "path": ["api","loans","history"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('History returns 200', function () { pm.response.to.have.status(200); });",
            "const body = pm.response.json();",
            "const returnedLoan = body.find(l => l.id === pm.collectionVariables.get('loanId'));",
            "pm.test('Returned loan appears in history', function () {",
            "    pm.expect(returnedLoan).to.not.be.undefined;",
            "});",
            "pm.test('Returned loan has RETURNED status in history', function () {",
            "    pm.expect(returnedLoan.status).to.equal('RETURNED');",
            "});",
            "pm.test('Returned loan has returnDate populated', function () {",
            "    pm.expect(returnedLoan.returnDate).to.not.be.null;",
            "});"
          ]}}]
        }
      ]
    },

    {
      "name": "10 - Reborrow After Return",
      "item": [
        {
          "name": "Borrow the same book again after returning (allowed)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{gatewayUrl}}/api/loans", "host": ["{{gatewayUrl}}"], "path": ["api","loans"] },
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"bookId\": {{bookId}},\n  \"email\": \"loan-user@elibrary.ie\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Re-borrow after return is allowed (201)', function () { pm.response.to.have.status(201); });",
            "const body = pm.response.json();",
            "pm.test('New loan has ACTIVE status', function () { pm.expect(body.status).to.equal('ACTIVE'); });",
            "pm.test('New loan has a different id', function () {",
            "    pm.expect(body.id).to.not.equal(pm.collectionVariables.get('loanId'));",
            "});",
            "pm.collectionVariables.set('loanId', body.id);",
            "console.log('Re-borrow successful, new loanId:', body.id);"
          ]}}]
        },
        {
          "name": "Return re-borrowed book (cleanup)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{gatewayUrl}}/api/loans/{{loanId}}/return",
              "host": ["{{gatewayUrl}}"], "path": ["api","loans","{{loanId}}","return"]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Cleanup return succeeds (200)', function () { pm.response.to.have.status(200); });"
          ]}}]
        }
      ]
    },

    {
      "name": "11 - Recommendation Service Integration",
      "item": [
        {
          "name": "Recommendations reflect loan history (borrow triggers event)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{gatewayUrl}}/api/recommendations", "host": ["{{gatewayUrl}}"], "path": ["api","recommendations"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Recommendations return 200', function () { pm.response.to.have.status(200); });",
            "const body = pm.response.json();",
            "pm.test('Recommendations is an array', function () { pm.expect(body).to.be.an('array'); });",
            "if (body.length > 0) {",
            "    pm.test('Borrowed book (bookId) not in recommendations (exclusion filter active)', function () {",
            "        const ids = body.map(r => String(r.bookId));",
            "        pm.expect(ids).to.not.include(pm.collectionVariables.get('bookId'));",
            "    });",
            "    pm.test('Each recommendation has bookId and score', function () {",
            "        body.forEach(r => {",
            "            pm.expect(r).to.have.property('bookId');",
            "            pm.expect(r).to.have.property('score');",
            "        });",
            "    });",
            "    console.log('Recommendations returned:', JSON.stringify(body));",
            "} else {",
            "    console.log('No recommendations yet (loan event may not have propagated via RabbitMQ)');",
            "}"
          ]}}]
        }
      ]
    }

  ]
}
