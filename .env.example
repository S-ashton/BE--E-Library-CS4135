# =============================================================================
# E-Library – environment variable reference
# =============================================================================
# All variables below have sensible defaults for local development.
# Copy this file to .env and uncomment/change values only when needed.
# The project runs out-of-the-box WITHOUT a .env file.
#
# Production: supply real values (never commit a populated .env to git).
# =============================================================================

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
# DB_USERNAME=elibrary
# DB_PASSWORD=elibrary-dev-password

# ---------------------------------------------------------------------------
# Message broker (RabbitMQ)
# ---------------------------------------------------------------------------
# RABBITMQ_USERNAME=elibrary
# RABBITMQ_PASSWORD=elibrary-dev-password

# ---------------------------------------------------------------------------
# Object storage (MinIO)
# ---------------------------------------------------------------------------
# MINIO_USER=elibrary
# MINIO_PASSWORD=elibrary-dev-password
# MINIO_BUCKET=book-covers

# ---------------------------------------------------------------------------
# JWT
# ---------------------------------------------------------------------------
# APP_JWT_SECRET=default-dev-jwt-secret-change-in-production-must-be-at-least-256-bits-long-for-hmac-sha
# APP_JWT_ISSUER=elibrary-user-service
# APP_JWT_EXPIRATION_SECONDS=3600
# Refresh-token cookie SameSite policy.
# Use None for HTTPS cross-site frontend/backend setups.
# APP_JWT_REFRESH_COOKIE_SAME_SITE=None

# ---------------------------------------------------------------------------
# CORS – frontend origin allowed by the API gateway
# Default is http://localhost:3000.
# Set this to the deployed frontend origin in production.
# ---------------------------------------------------------------------------
# APP_FRONTEND_ORIGIN=http://localhost:3000

# ---------------------------------------------------------------------------
# API Gateway public base URL — used in generated OpenAPI server entries
# Set this to production domain when deploying (e.g. https://api.yourdomain.com).
# Default is http://localhost:8080.
# ---------------------------------------------------------------------------
# APP_BASE_URL=https://api.yourdomain.com

# ---------------------------------------------------------------------------
# Email notifications (SendGrid) – OPTIONAL
# Leave unset to disable email sending; all other features continue to work.
# ---------------------------------------------------------------------------
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
# SENDGRID_FROM_EMAIL=noreply@yourdomain.com
# SENDGRID_FROM_NAME=E-Library

# ---------------------------------------------------------------------------
# Production / Traefik TLS  (not needed for local Docker Compose)
# DOMAIN is the public backend domain used by Traefik and HTTPS routing.
# ---------------------------------------------------------------------------
# DOMAIN=api.yourdomain.com
# ACME_EMAIL=admin@yourdomain.com
