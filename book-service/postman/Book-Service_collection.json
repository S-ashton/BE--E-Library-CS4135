{
  "info": {
    "name": "Book Service Testing",
    "_postman_id": "book-service-gateway-tests-001",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "End-to-end tests for the book-service routed through the API gateway (port 8080). The gateway validates the JWT, strips incoming X-Authenticated-* headers, and forwards trusted identity to the service. Run folders in order as later ones depend on data created by earlier ones."
  },
  "variable": [
    { "key": "gatewayUrl", "value": "http://localhost:8080" },
    { "key": "userEmail", "value": "booktest-user@elibrary.ie" },
    { "key": "userPassword", "value": "Test@12345" },
    { "key": "staffEmail", "value": "booktest-staff@elibrary.ie" },
    { "key": "staffPassword", "value": "Test@12345" },
    { "key": "adminEmail", "value": "booktest-admin@elibrary.ie" },
    { "key": "adminPassword", "value": "Test@12345" },
    { "key": "userToken", "value": "" },
    { "key": "staffToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "createdTitleId", "value": "" },
    { "key": "createdCopyId", "value": "" },
    { "key": "adminTitleId", "value": "" },
    { "key": "adminCopyId", "value": "" }
  ],
  "item": [
    {
      "name": "0 - Setup",
      "description": "Registers USER, STAFF and ADMIN accounts then logs in to capture JWT tokens. 201 means newly created, 409 means the account already exists from a previous run - both are acceptable.",
      "item": [
        {
          "name": "Register USER account",
          "request": {
            "method": "POST",
            "url": { "raw": "{{gatewayUrl}}/api/auth/register", "host": ["{{gatewayUrl}}"], "path": ["api", "auth", "register"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\",\n  \"role\": \"USER\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('USER account ready (201 or 409)', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([201, 409]);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Register STAFF account",
          "request": {
            "method": "POST",
            "url": { "raw": "{{gatewayUrl}}/api/auth/register", "host": ["{{gatewayUrl}}"], "path": ["api", "auth", "register"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{staffEmail}}\",\n  \"password\": \"{{staffPassword}}\",\n  \"role\": \"STAFF\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('STAFF account ready (201 or 409)', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([201, 409]);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Register ADMIN account",
          "request": {
            "method": "POST",
            "url": { "raw": "{{gatewayUrl}}/api/auth/register", "host": ["{{gatewayUrl}}"], "path": ["api", "auth", "register"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\",\n  \"role\": \"ADMIN\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('ADMIN account ready (201 or 409)', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([201, 409]);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login as USER",
          "request": {
            "method": "POST",
            "url": { "raw": "{{gatewayUrl}}/api/auth/login", "host": ["{{gatewayUrl}}"], "path": ["api", "auth", "login"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('USER login returns 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response contains JWT token', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('token');",
                  "    pm.expect(body.token).to.be.a('string').and.not.empty;",
                  "    pm.collectionVariables.set('userToken', body.token);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login as STAFF",
          "request": {
            "method": "POST",
            "url": { "raw": "{{gatewayUrl}}/api/auth/login", "host": ["{{gatewayUrl}}"], "path": ["api", "auth", "login"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{staffEmail}}\",\n  \"password\": \"{{staffPassword}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('STAFF login returns 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response contains JWT token', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('token');",
                  "    pm.expect(body.token).to.be.a('string').and.not.empty;",
                  "    pm.collectionVariables.set('staffToken', body.token);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login as ADMIN",
          "request": {
            "method": "POST",
            "url": { "raw": "{{gatewayUrl}}/api/auth/login", "host": ["{{gatewayUrl}}"], "path": ["api", "auth", "login"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('ADMIN login returns 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response contains JWT token', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('token');",
                  "    pm.expect(body.token).to.be.a('string').and.not.empty;",
                  "    pm.collectionVariables.set('adminToken', body.token);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "1 - Authentication",
      "description": "Verifies unauthenticated and malformed requests are rejected at the gateway.",
      "item": [
        {
          "name": "Search with no token",
          "request": {
            "method": "GET",
            "url": { "raw": "{{gatewayUrl}}/api/books/search", "host": ["{{gatewayUrl}}"], "path": ["api", "books", "search"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('No token returns 401', function () {",
                  "    pm.response.to.have.status(401);",
                  "});",
                  "pm.test('Error body has correct structure', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('status', 401);",
                  "    pm.expect(body).to.have.property('error');",
                  "    pm.expect(body).to.have.property('message');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Add title with no token",
          "request": {
            "method": "POST",
            "url": { "raw": "{{gatewayUrl}}/api/books/addTitle", "host": ["{{gatewayUrl}}"], "path": ["api", "books", "addTitle"] },
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Unauthorised", "type": "text" },
                { "key": "author", "value": "Nobody", "type": "text" },
                { "key": "description", "value": "No auth", "type": "text" },
                { "key": "yearPublished", "value": "2024", "type": "text" },
                { "key": "genre", "value": "FANTASY", "type": "text" },
                { "key": "language", "value": "ENGLISH", "type": "text" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('No token on POST returns 401', function () {",
                  "    pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Spoofed identity headers without bearer token",
          "description": "Gateway strips incoming X-Authenticated-* headers. Sending them without a valid token must still return 401.",
          "request": {
            "method": "GET",
            "url": { "raw": "{{gatewayUrl}}/api/books/search", "host": ["{{gatewayUrl}}"], "path": ["api", "books", "search"] },
            "header": [
              { "key": "X-Authenticated-User", "value": "hacker@evil.com" },
              { "key": "X-Authenticated-Role", "value": "ADMIN" },
              { "key": "X-Authenticated-User-Id", "value": "1" }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Spoofed headers without bearer token rejected with 401', function () {",
                  "    pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Invalid token",
          "request": {
            "method": "GET",
            "url": { "raw": "{{gatewayUrl}}/api/books/search", "host": ["{{gatewayUrl}}"], "path": ["api", "books", "search"] },
            "header": [{ "key": "Authorization", "value": "Bearer this.is.not.a.valid.jwt" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Malformed token returns 401', function () {",
                  "    pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Expired or tampered token",
          "request": {
            "method": "GET",
            "url": { "raw": "{{gatewayUrl}}/api/books/search", "host": ["{{gatewayUrl}}"], "path": ["api", "books", "search"] },
            "header": [{ "key": "Authorization", "value": "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJ0ZXN0QGV4YW1wbGUuY29tIiwicm9sZSI6IlVTRVIiLCJ1c2VySWQiOjEsImlhdCI6MTYwMDAwMDAwMCwiZXhwIjoxNjAwMDAwMDAxfQ.invalidsignature" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Expired or tampered token returns 401', function () {",
                  "    pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "2 - Catalogue Setup (STAFF)",
      "description": "STAFF creates a title and a copy. IDs are stored as collection variables for all subsequent folders.",
      "item": [
        {
          "name": "STAFF add title",
          "request": {
            "method": "POST",
            "url": { "raw": "{{gatewayUrl}}/api/books/addTitle", "host": ["{{gatewayUrl}}"], "path": ["api", "books", "addTitle"] },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{staffToken}}" }] },
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "The Great Gatsby (GW)", "type": "text" },
                { "key": "author", "value": "F. Scott Fitzgerald", "type": "text" },
                { "key": "description", "value": "A novel about the American dream set in the Jazz Age", "type": "text" },
                { "key": "yearPublished", "value": "1925", "type": "text" },
                { "key": "genre", "value": "FANTASY", "type": "text" },
                { "key": "language", "value": "ENGLISH", "type": "text" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('STAFF can add or retrieve title', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([201, 409]);",
                  "});",
                  "const body = pm.response.json();",
                  "if (pm.response.code === 201) {",
                  "    pm.collectionVariables.set('createdTitleId', body.id);",
                  "} else {",
                  "    pm.collectionVariables.set('createdTitleId', body.existingId);",
                  "}",
                  "pm.test('Title ID is stored', function () {",
                  "    pm.expect(pm.collectionVariables.get('createdTitleId')).to.be.ok;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "STAFF add copy",
          "request": {
            "method": "POST",
            "url": { "raw": "{{gatewayUrl}}/api/books/addCopy", "host": ["{{gatewayUrl}}"], "path": ["api", "books", "addCopy"] },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{staffToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{{createdTitleId}}" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('STAFF can add a copy', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Copy is AVAILABLE and ID is stored', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('id');",
                  "    pm.expect(body.status).to.eql('AVAILABLE');",
                  "    pm.collectionVariables.set('createdCopyId', body.id);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "3 - Read Access",
      "description": "All authenticated roles can read catalogue data. Covers search variants, get by ID, bulk ID lookup, and available copy lookup.",
      "item": [
        {
          "name": "USER search all books",
          "request": {
            "method": "GET",
            "url": { "raw": "{{gatewayUrl}}/api/books/search", "host": ["{{gatewayUrl}}"], "path": ["api", "books", "search"] },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{userToken}}" }] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('USER search returns 200/201', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "pm.test('Response is an array', function () {",
                  "    pm.expect(pm.response.json()).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "USER search by keyword",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{gatewayUrl}}/api/books/search?keyword=gatsby",
              "host": ["{{gatewayUrl}}"],
              "path": ["api", "books", "search"],
              "query": [{ "key": "keyword", "value": "gatsby" }]
            },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{userToken}}" }] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Keyword search returns 200/201', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "pm.test('Result is an array containing the created title', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.be.an('array');",
                  "    const found = body.some(b => b.title === 'The Great Gatsby (GW)');",
                  "    pm.expect(found).to.be.true;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "USER search by genre",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{gatewayUrl}}/api/books/search?genre=FANTASY",
              "host": ["{{gatewayUrl}}"],
              "path": ["api", "books", "search"],
              "query": [{ "key": "genre", "value": "FANTASY" }]
            },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{userToken}}" }] }
          },
          "event": [
            {
              "listen": "test",
