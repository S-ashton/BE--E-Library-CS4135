                "type": "text/javascript",
                "exec": [
                  "pm.test('Titles by IDs returns 200/201', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "pm.test('Response is an array with the requested title', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.be.an('array').with.lengthOf(1);",
                  "    pm.expect(body[0].title).to.eql('The Great Gatsby (GW)');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "USER get available copy",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{gatewayUrl}}/api/books/getAvailableCopy?bookId={{createdTitleId}}",
              "host": ["{{gatewayUrl}}"],
              "path": ["api", "books", "getAvailableCopy"],
              "query": [{ "key": "bookId", "value": "{{createdTitleId}}" }]
            },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{userToken}}" }] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Get available copy returns 200/201', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "pm.test('Response has an AVAILABLE copy', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('id');",
                  "    pm.expect(body.status).to.eql('AVAILABLE');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "4 - Authorization: USER Cannot Write",
