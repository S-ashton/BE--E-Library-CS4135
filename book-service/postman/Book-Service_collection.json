                "type": "text/javascript",
                "exec": [
                  "pm.test('Genre filter returns 200/201', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "pm.test('Response is an array', function () {",
                  "    pm.expect(pm.response.json()).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "USER search by year",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{gatewayUrl}}/api/books/search?year=1925",
              "host": ["{{gatewayUrl}}"],
              "path": ["api", "books", "search"],
              "query": [{ "key": "year", "value": "1925" }]
            },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{userToken}}" }] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Year filter returns 200/201', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "pm.test('Response is an array', function () {",
                  "    pm.expect(pm.response.json()).to.be.an('array');",
