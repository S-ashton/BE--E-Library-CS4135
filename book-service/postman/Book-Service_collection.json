            "method": "GET",
            "url": {
              "raw": "{{gatewayUrl}}/api/books/search?language=ENGLISH",
              "host": ["{{gatewayUrl}}"],
              "path": ["api", "books", "search"],
              "query": [{ "key": "language", "value": "ENGLISH" }]
            },
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{userToken}}" }] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Language filter returns 200/201', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "pm.test('Response is an array', function () {",
                  "    pm.expect(pm.response.json()).to.be.an('array');",
